#let icon-camera = text(size: 12pt)[#emoji.camera]
#let icon-clock = text(size: 12pt)[#emoji.clock]
#let icon-cold = text(size: 12pt)[#emoji.snowflake]
#let icon-cool = text(size: 12pt)[#emoji.snowflake]
#let icon-drop = text(size: 12pt)[#emoji.drops]
#let icon-fire = text(size: 12pt)[#emoji.fire]
#let icon-food = text(size: 12pt)[#emoji.bread]
#let icon-glove = text(size: 12pt)[#emoji.hand]
#let icon-heart = text(size: 12pt)[#emoji.heart]
#let icon-med = text(size: 12pt)[#emoji.pill]
#let icon-monitor = text(size: 12pt)[#emoji.eye]
#let icon-person = text(size: 12pt)[#emoji.person]
#let icon-phone = text(size: 12pt)[#emoji.phone]
#let icon-press = text(size: 12pt)[#emoji.hand]
#let icon-search = text(size: 12pt)[#emoji.magnify.l]
#let icon-shield = text(size: 12pt)[#emoji.shield]
#let icon-sit = text(size: 12pt)[#emoji.person]
#let icon-snake = text(size: 12pt)[#emoji.snake]
#let icon-spider = text(size: 12pt)[#emoji.spider]
#let icon-syringe = text(size: 12pt)[#emoji.syringe]
#let icon-temp = text(size: 12pt)[#emoji.thermometer]
#let icon-thermo = text(size: 12pt)[#emoji.thermometer]
#let icon-thermometer = text(size: 12pt)[#emoji.thermometer]
#let icon-warm = text(size: 12pt)[#emoji.fire]
#let icon-warn = text(size: 12pt)[#emoji.warning]
#let icon-warning = text(size: 12pt)[#emoji.warning]
#let icon-water = text(size: 12pt)[#emoji.drops]
#let icon-zap = text(size: 12pt)[#emoji.lightning]

// === PAGE SETUP ===
#set page(
  paper: "a4",
  margin: (top: 2.8cm, bottom: 2cm, left: 1.5cm, right: 1.5cm),
  header: context {
    let p = current-protocol.get()
    let age-clr = if p.age == "CHILD" { clr-age-child } else { clr-age-adult }
    let page-num = counter(page).get().first()
    let page-total = counter(page).final().first()
    rect(fill: age-clr, width: 100%, height: 3pt, radius: (top: 2pt, bottom: 0pt))[]
    rect(fill: clr-header-bg, width: 100%, inset: (x: 10pt, y: 6pt), stroke: (bottom: 1pt + clr-header-border))[
      #grid(
        columns: (60pt, 1fr, 60pt),
        gutter: 0pt,
        [],
        align(center)[
          #text(size: 15pt, weight: "bold", fill: age-clr, tracking: 0.5pt)[#upper(p.age)]
          #h(5pt)
          #text(size: 11pt, fill: rgb("#94a3b8"))[#sym.triangle.stroked.r]
          #h(5pt)
          #text(size: 15pt, weight: "bold", fill: clr-condition, tracking: 0.5pt)[#upper(p.subject)]
          #h(5pt)
          #text(size: 11pt, fill: rgb("#94a3b8"))[#sym.triangle.stroked.r]
          #h(5pt)
          #text(size: 15pt, weight: "bold", fill: clr-scenario, tracking: 0.5pt)[#upper(p.scenario)]
          #v(3pt)
          #text(size: 8pt, fill: rgb("#94a3b8"), tracking: 1pt)[SOP #p.sop]
        ],
        align(right + horizon)[
          #rect(fill: clr-page-bg, radius: 4pt, inset: (x: 10pt, y: 5pt))[
            #text(fill: clr-page-fg, weight: "bold", size: 14pt)[#page-num]#text(fill: rgb("#94a3b8"), weight: "bold", size: 14pt)[ \/ ]#text(fill: clr-page-fg, weight: "bold", size: 14pt)[#page-total]
          ]
        ],
      )
    ]
  },
  footer: context {
    let p = current-protocol.get()
    let page-num = counter(page).get().first()
    let page-total = counter(page).final().first()
    rect(fill: clr-header-bg, width: 100%, inset: (x: 10pt, y: 6pt), stroke: (top: 1pt + clr-header-border, bottom: 0pt), radius: (top: 0pt, bottom: 2pt))[
      #grid(
        columns: (1fr, auto, 1fr),
        gutter: 0pt,
        align(left + horizon)[
          #text(size: 7pt, fill: rgb("#94a3b8"))[
            #text(weight: "bold", fill: rgb("#64748b"))[#p.id] · v#p.version \
            #p.generation_date · #p.source
          ]
        ],
        align(center + horizon)[
          #rect(fill: rgb("#fef3c7"), radius: 3pt, inset: (x: 8pt, y: 3pt), stroke: 0.5pt + rgb("#f59e0b"))[
            #text(size: 7pt, fill: rgb("#92400e"), weight: "bold")[
              Personal reference only — not medical advice
            ]
          ]
          #v(2pt)
          #text(size: 5.5pt, fill: rgb("#94a3b8"))[
            Daniel Rosehill · share with attribution
          ]
        ],
        align(right + horizon)[
          #rect(fill: clr-page-bg, radius: 3pt, inset: (x: 8pt, y: 3pt))[
            #text(fill: clr-page-fg, weight: "bold", size: 11pt)[#page-num]#text(fill: rgb("#94a3b8"), weight: "bold", size: 11pt)[ \/ ]#text(fill: clr-page-fg, weight: "bold", size: 11pt)[#page-total]
          ]
        ],
      )
    ]
  },
)

#set text(font: ("IBM Plex Sans", "IBM Plex Sans Hebrew"), size: 10pt, dir: ltr)

// === HELPERS ===
#let action(word) = { text(weight: "bold", fill: clr-condition, size: 11pt)[#upper(word)] }

#let yes-label = rect(fill: clr-yes, radius: 10pt, inset: (x: 6pt, y: 2pt))[#text(fill: white, weight: "bold", size: 11pt)[Y]]
#let no-label = rect(fill: clr-no, radius: 10pt, inset: (x: 6pt, y: 2pt))[#text(fill: white, weight: "bold", size: 11pt)[N]]

#let keep-together(body) = { block(breakable: false)[#body] }

#let do-not-box(items) = {
  keep-together[
    #rect(fill: clr-warning-fill, stroke: 2pt + clr-warning, radius: 6pt, width: 100%, inset: 10pt)[
      #set text(size: 10pt)
      #text(fill: clr-warning, weight: "bold", size: 13pt)[DO NOT:]
      #v(4pt)
      #for item in items [
        #text(fill: clr-warning, weight: "bold")[#emoji.crossmark] #item \
      ]
    ]
  ]
}

#let equipment-box(items) = {
  keep-together[
    #rect(fill: clr-equip-fill, stroke: 1pt + rgb("#ca8a04"), radius: 6pt, width: 100%, inset: 10pt)[
      #set text(size: 10pt)
      #text(fill: clr-equip, weight: "bold", size: 11pt)[Equipment needed:]
      #v(4pt)
      #for item in items [ — #item \ ]
    ]
  ]
}

