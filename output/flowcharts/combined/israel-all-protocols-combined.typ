))
// ============================================================
// PAGE 1: Flowchart — Assessment and age-based branching
// ============================================================

#diagram(
  spacing: (8mm, 5mm),
  node-stroke: 1pt,
  edge-stroke: 1.5pt,

  // Confirm unconscious but breathing
  node((0, 0), align(center)[
