  edge((-1, 4), (-0.5, 5), "->",
    stroke: 1pt + clr-rejoin, dash: "dashed"),

  edge((0, 4), (0, 5), "->"),

  // Expose chest and apply pads
  node((0, 5), align(center)[
    #action[EXPOSE] bare chest. \
    Dry skin. Remove patches.
  ],
