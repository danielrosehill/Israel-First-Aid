  ],
    shape: rect, fill: clr-no-fill, stroke: 1pt + clr-no,
    width: 50mm, inset: 8pt, corner-radius: 6pt),

  // Rejoin
  edge((1, 1), (0.5, 2), "->",
    stroke: 1pt + clr-rejoin, dash: "dashed"),
  edge((-1, 1), (-0.5, 2), "->",
    stroke: 1pt + clr-rejoin, dash: "dashed"),

  edge((0, 1), (0, 2), "->"),

  // CPR while waiting
  node((0, 2), align(center)[
    #icon-heart #action[PERFORM] CPR \
    appropriate to age.
    #v(3pt)
