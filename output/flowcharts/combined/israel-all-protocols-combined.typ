    edge((0, 1), (-1, 1), "->",
      label: no-label,
      label-side: center),

    node((-1, 1), align(center)[
      #icon-monitor Keep upright.
      #v(3pt)
      Continue monitoring \
      until help arrives.
      #v(2pt)
