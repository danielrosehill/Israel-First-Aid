// ============================================================
// ADULT — ASTHMA (SOP 001) [israel-adult-asthma.typ]
// ============================================================

#current-protocol.update((
  id: "IL-ADULT-ASTHMA-001",
  subject: "ASTHMA",
  scenario: "ACUTE ATTACK",
  sop: "001",
  age: "ADULT",
  version: "3.0",
  source: "Magen David Adom",
  generation_date: "2026-03-16",
))
// ============================================================
// PAGE 1: Flowchart — Initial response through assessment
// ============================================================

#diagram(
  spacing: (8mm, 5mm),
  node-stroke: 1pt,
  edge-stroke: 1.5pt,

  // Action: Position upright
  node((0, 0), align(center)[
    #icon-sit #action[HELP] sit upright \
    or lean slightly forward.
  ],
    shape: rect, fill: clr-step, stroke: 1pt + clr-step-stroke,
    width: 52mm, inset: 6pt, corner-radius: 6pt),

  edge((0, 0), (0, 1), "->"),

  // Action: Reassure
  node((0, 1), align(center)[
    #icon-calm #action[REASSURE] and calm. \
    Stay with them.
  ],
    shape: rect, fill: clr-step, stroke: 1pt + clr-step-stroke,
    width: 52mm, inset: 6pt, corner-radius: 6pt),

  edge((0, 1), (0, 2), "->"),

  // Decision: Inhaler available?
  node((0, 2), align(center)[
    #icon-breath Rescue inhaler \
    (Ventolin) available?
  ],
    shape: rect, fill: clr-decision, stroke: 2pt + clr-decision-stroke,
    width: 52mm, inset: 6pt, corner-radius: 6pt),

  edge((0, 2), (1, 2), "->",
    label: yes-label,
    label-side: center),

  node((1, 2), align(center)[
    #icon-med #action[PROVIDE] \
    inhaler immediately.
  ],
    shape: rect, fill: clr-yes-fill, stroke: 1pt + clr-yes,
    width: 40mm, inset: 6pt, corner-radius: 6pt),

  // Rejoin: YES branch flows back to main
  edge((1, 2), (0.5, 3), "->",
    stroke: 1pt + clr-rejoin,
    dash: "dashed"),

  edge((0, 2), (-1, 2), "->",
    label: no-label,
    label-side: center),

  // MDA logo centered above the NO/call box
  node((-1, 1.5), align(center)[
    #image(mda-logo, width: 24pt)
  ],
    shape: rect, fill: none, stroke: none,
    width: 14mm, inset: 0pt),

  node((-1, 2), align(center)[
    #icon-phone #action[CALL] 101 \
    immediately.
    #v(3pt)
    Monitor and reassure.
  ],
    shape: rect, fill: clr-no-fill, stroke: 1pt + clr-no,
    width: 40mm, inset: 6pt, corner-radius: 6pt),

  edge((0, 2), (0, 3), "->"),

  // Action: Administer inhaler
  node((0, 3), align(center)[
    #icon-med #action[ADMINISTER] rescue \
    inhaler: 2–4 puffs.
    #v(3pt)
    Use spacer if available.
  ],
    shape: rect, fill: clr-step, stroke: 1pt + clr-step-stroke,
    width: 52mm, inset: 6pt, corner-radius: 6pt),

  edge((0, 3), (0, 4), "->"),

  // Decision: Breathing improved?
  node((0, 4), align(center)[
    #icon-breath Breathing improved \
    after initial dose?
  ],
    shape: rect, fill: clr-decision, stroke: 2pt + clr-decision-stroke,
    width: 52mm, inset: 6pt, corner-radius: 6pt),

  edge((0, 4), (1, 4), "->",
    label: yes-label,
    label-side: center),

  node((1, 4), align(center)[
    #icon-monitor Continue monitoring.
    #v(3pt)
    Repeat 2–4 puffs \
    if symptoms return.
    #v(2pt)
    #line(length: 100%, stroke: 1.5pt + clr-terminal)
  ],
    shape: rect, fill: clr-yes-fill, stroke: 1pt + clr-yes,
    width: 40mm, inset: 6pt, corner-radius: 6pt),

  edge((0, 4), (-1, 4), "->",
    label: no-label,
    label-side: center),

  node((-1, 4), align(center)[
    Repeat 2–4 puffs.
    #v(3pt)
    No improvement? \
    Proceed below.
  ],
    shape: rect, fill: clr-no-fill, stroke: 1pt + clr-no,
    width: 40mm, inset: 6pt, corner-radius: 6pt),

  // Rejoin: NO branch flows back to main
  edge((-1, 4), (-0.5, 5), "->",
    stroke: 1pt + clr-rejoin,
    dash: "dashed"),

  edge((0, 4), (0, 5), "->"),

  // MDA logo centered above the call box
  node((0, 4.5), align(center)[
    #image(mda-logo, width: 24pt)
  ],
    shape: rect, fill: none, stroke: none,
    width: 14mm, inset: 0pt),

  // Action: Call 101 if no improvement
  node((0, 5), align(center)[
    #icon-phone #action[CALL] 101
    #v(3pt)
    No improvement after \
    repeated use.
  ],
    shape: rect, fill: clr-step, stroke: 1pt + clr-step-stroke,
    width: 52mm, inset: 6pt, corner-radius: 6pt),

  edge((0, 5), (0, 6), "->"),

  // Decision: Life-threatening signs?
  node((0, 6), align(center)[
    *Cannot speak in sentences?*
    #v(2pt)
    *Blue lips? Silent chest?*
    #v(2pt)
    *Loss of consciousness?*
  ],
    shape: rect, fill: clr-decision, stroke: 2pt + clr-decision-stroke,
    width: 52mm, inset: 6pt, corner-radius: 6pt),

  edge((0, 6), (1, 6), "->",
    label: yes-label,
    label-side: center),

  // MDA logo centered above the life-threatening call box
  node((1, 5.5), align(center)[
    #image(mda-logo, width: 24pt)
  ],
    shape: rect, fill: none, stroke: none,
    width: 14mm, inset: 0pt),

  node((1, 6), align(center)[
    Life-threatening.
    #v(3pt)
    #action[CALL] 101 immediately. \
    Keep upright.
    #v(2pt)
    #line(length: 100%, stroke: 1.5pt + clr-terminal)
  ],
    shape: rect, fill: clr-warning-fill, stroke: 2pt + clr-warning,
    width: 40mm, inset: 6pt, corner-radius: 6pt),

  edge((0, 6), (-1, 6), "->",
    label: no-label,
    label-side: center),

  node((-1, 6), align(center)[
    #icon-monitor Continue monitoring.
    #v(3pt)
    Seek medical evaluation \
    even if improved.
    #v(2pt)
    #line(length: 100%, stroke: 1.5pt + clr-terminal)
  ],
    shape: rect, fill: clr-no-fill, stroke: 1pt + clr-no,
    width: 40mm, inset: 6pt, corner-radius: 6pt),
)

