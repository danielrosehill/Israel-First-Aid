    #v(3pt)
    #action[BEGIN] CPR immediately.
  ],
    shape: rect, fill: clr-yes-fill, stroke: 1pt + clr-yes,
    width: 50mm, inset: 8pt, corner-radius: 6pt),

  edge((0, 1), (-1, 1), "->",
    label: no-label,
    label-side: center),

  node((-1, 1), align(center)[
    #icon-heart #action[BEGIN] CPR for \
