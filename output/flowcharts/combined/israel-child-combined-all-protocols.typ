  edge((1, 3), (1, 4), "->"),

  node((1, 4), align(center)[
    #action[PERFORM] abdominal thrusts. \
    Stand/kneel behind child. \
    Fist above navel, below ribs. \
    Thrust inward and upward.
  ],
