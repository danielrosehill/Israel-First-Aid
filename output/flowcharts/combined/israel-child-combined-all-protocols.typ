  ],
    shape: rect, fill: clr-decision, stroke: 2pt + clr-decision-stroke,
    width: 40mm, inset: 6pt, corner-radius: 6pt),

  edge((-1, 6), (-1, 7), "->",
    label: no-label,
    label-side: center),

  node((-1, 7), align(center)[
    #action[ALTERNATE] 5 back blows \
    and 5 chest thrusts. \
    If loses consciousness: \
    proceed to CPR (page 2).
    #v(2pt)
