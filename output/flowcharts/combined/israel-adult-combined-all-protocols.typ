// ============================================================
// PAGE 2: AED pad placement and shock delivery
// ============================================================
#pagebreak()

#align(center)[
  #text(size: 16pt, weight: "bold", fill: clr-condition)[AED Pad Placement & Shock Delivery]
]
#v(6pt)

#diagram(
  spacing: (8mm, 5mm),
  node-stroke: 1pt,
