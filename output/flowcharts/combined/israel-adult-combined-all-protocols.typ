    Shave hair at pad sites. \
    Remove medication patches. \
    Place pads 2.5 cm from \
    pacemaker. Move off metal.
  ],
    shape: rect, fill: clr-yes-fill, stroke: 1pt + clr-yes,
    width: 42mm, inset: 6pt, corner-radius: 6pt),

  edge((1, 2), (0.5, 3), "->",
